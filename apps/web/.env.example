# Supabase — required. Get these from your Supabase project settings.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# AI Coach provider. Default is "free" — a rule-based responder, $0, no key needed.
# Options: free | ollama | anthropic | openai
AI_PROVIDER=ollama

# Optional: real fallback CHAIN. If Ollama is slow/down, it automatically
# tries the next one — "free" is always appended as the guaranteed last resort.
# Uncomment and set keys below to enable more than one real provider:
# AI_PROVIDER_CHAIN=ollama,anthropic,openai

# How long (ms) each provider gets before the chain moves to the next one.
AI_TIMEOUT_MS=20000

# Only needed if AI_PROVIDER=ollama (must have Ollama running locally: https://ollama.com)
OLLAMA_MODEL=llama3.1
OLLAMA_BASE_URL=http://localhost:11434
# Food photo recognition needs a VISION-capable Ollama model (llama3.1 can't see images).
# Run: ollama pull llava
OLLAMA_VISION_MODEL=llava

# Only needed if AI_PROVIDER=anthropic, or included in AI_PROVIDER_CHAIN
ANTHROPIC_API_KEY=

# Only needed if AI_PROVIDER=openai, or included in AI_PROVIDER_CHAIN
OPENAI_API_KEY=
